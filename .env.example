# Скопируй в .env и заполни. Никогда не публикуй этот файл с реальными значениями.

TELEGRAM_BOT_TOKEN=
# Можно указать несколько админов через запятую: 111111,222222
ADMIN_CHAT_IDS=

# --- Bybit (полная автоматика: объявления + ордера) ---
BYBIT_ENABLED=True
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=False

# --- Bitget (автоматика: список объявлений + ордеров, нужен статус верифицированного мерчанта) ---
BITGET_ENABLED=True
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# --- HTX (ручной режим - ссылка и цена задаются вручную командами боту) ---
HTX_ENABLED=True

# --- MEXC (ручной режим) ---
MEXC_ENABLED=True
# file_id стикера приветствия (необязательно). Как получить - см. инструкцию в чате
WELCOME_STICKER_ID=
# Твой контакт для клиентов, если возникнут вопросы (юзернейм в Telegram)
SUPPORT_CONTACT=@your_username
BOT_USERNAME=crypto006_bot
WORKING_SINCE_YEAR=2024
